<Window x:Class="BlockParam.UI.LoadingSplash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="White"
        FontFamily="Segoe UI" FontSize="12">
    <Border BorderBrush="#FF3A6EA5" BorderThickness="1" Padding="24,20" MinWidth="360">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                       Foreground="#FF202020" Margin="0,0,0,12"/>
            <TextBlock Text="{Binding StatusText}" Foreground="#FF404040"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
            <TextBlock Foreground="#FF808080" FontSize="11" Margin="0,0,0,12"
                       Text="{Binding CounterText}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CounterText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <ProgressBar IsIndeterminate="True" Height="6" Width="320"
                         Foreground="#FF0078D4" Background="#FFE6E6E6"
                         BorderThickness="0"/>
            <!-- #127: rotating quip line. Smaller, dimmer, italic — sits UNDER
                 the load-bearing status line and never replaces it. Collapsed
                 (and zero-height) until HumorLine is set, so fast opens show
                 no quip and no reserved gap. -->
            <TextBlock Foreground="#FFA0A0A0" FontSize="11" FontStyle="Italic"
                       TextTrimming="CharacterEllipsis" Margin="0,12,0,0"
                       Text="{Binding HumorLine}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HumorLine}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</Window>
