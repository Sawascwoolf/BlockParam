<UserControl x:Class="BlockParam.UI.Controls.PillMultiSelect.PillMultiSelect"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BlockParam.UI.Controls.PillMultiSelect"
             FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Pill trigger button: rounded chrome, blue tint when something is selected. -->
        <Style x:Key="PillTriggerStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#E1E4E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="PillBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="#E7F1FB"/>
                                <Setter TargetName="PillBorder" Property="BorderBrush" Value="#C2DBF1"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillBorder" Property="BorderBrush" Value="#9CC3EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact, chrome-free button used for the X (clear) on the trigger. -->
        <Style x:Key="PillIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A000000"/>
                    <Setter Property="Foreground" Value="#1F2937"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ToggleButton x:Name="PillTrigger"
                      Style="{StaticResource PillTriggerStyle}"
                      IsChecked="{Binding IsOpen, Mode=TwoWay}"
                      ToolTip="{Binding SelectionTooltip}"
                      ToolTipService.InitialShowDelay="600"
                      ToolTipService.ShowDuration="20000"
                      AutomationProperties.Name="{Binding Label}">
            <StackPanel Orientation="Horizontal">
                <!-- Optional leading icon. Bound to VM.Icon (Geometry?). When
                     null the Path collapses, leaving the label flush left. -->
                <Path Data="{Binding Icon}"
                      Fill="#1F2937"
                      Stretch="Uniform" Width="14" Height="14"
                      VerticalAlignment="Center" Margin="0,0,6,0"
                      Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding Label}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SelectedAbbreviationsText}"
                           Foreground="#6B7280"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"
                           Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}"/>
                <!-- Count badge: filled blue circle with white number. Hidden
                     when nothing is selected so the empty pill is uncluttered. -->
                <Border Background="#0078D7"
                        CornerRadius="9"
                        MinWidth="18" Height="18"
                        Padding="5,0"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding SelectedCount}"
                               Foreground="White" FontSize="10" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- Clear (X). Click is intercepted in code-behind so the
                     parent ToggleButton doesn't ALSO toggle the popup open
                     when the user just wanted to wipe the selection. -->
                <Button x:Name="ClearButton"
                        Style="{StaticResource PillIconButton}"
                        Command="{Binding ClearCommand}"
                        Click="OnClearClick"
                        Margin="6,0,-4,0"
                        Width="18" Height="18"
                        ToolTip="{Binding ClearTooltip}"
                        Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="✕" FontSize="11" Margin="0,-1,0,0"/>
                </Button>
            </StackPanel>
        </ToggleButton>

        <Popup x:Name="PillPopup"
               IsOpen="{Binding IsOpen, Mode=TwoWay}"
               PlacementTarget="{Binding ElementName=PillTrigger}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               HorizontalOffset="0" VerticalOffset="4"
               Opened="OnPopupOpened">
            <!--
                Popup chrome (rounded white card + drop shadow) lives here
                on the pill side so MultiSelectDropdown stays chrome-agnostic —
                DataGrid cells, fly-out panels, or other hosts can wrap the
                dropdown in their own container. Width binding stays on the
                outer Border so the dropdown's intrinsic sizing kicks in
                when used standalone.
            -->
            <Border Background="White"
                    CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Margin="0,0,12,12"
                    Width="{Binding PopupWidth}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.18"
                                      BlurRadius="14" ShadowDepth="3"
                                      Direction="270"/>
                </Border.Effect>
                <!-- DataContext inherits from the popup's content (which the
                     code-behind sets to _internalState); the dropdown reads
                     the same state the trigger does. -->
                <local:MultiSelectDropdown x:Name="Dropdown"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>
